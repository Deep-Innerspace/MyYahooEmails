# Copy this file to config.yaml and customize
# config.yaml is gitignored and never committed

imap:
  server: imap.mail.yahoo.com
  port: 993
  ssl: true

# LLM provider routing — controls which provider handles each task type
# Providers: claude, openai, groq, ollama
llm:
  default_provider: groq          # Used when no task-specific provider is set
  task_providers:
    classify: groq                # Topic classification (cheap, high volume)
    tone: groq                    # Tone analysis (cheap, high volume)
    timeline: groq                # Event extraction
    contradictions: groq          # Deep reasoning (switch to claude for production)
    manipulation: groq            # Deep reasoning (switch to claude for production)
    court_correlation: groq       # Narrative synthesis (switch to claude for production)
    reply_draft: claude           # Reply generation

  # Provider-specific settings
  providers:
    claude:
      model: claude-sonnet-4-6
    openai:
      model: gpt-4o-mini
    groq:
      model: llama-3.3-70b-versatile
      # ── Groq free-tier rate limits ───────────────────────────────────────
      # Groq enforces TWO independent dimensions simultaneously:
      #
      #   Per-minute (TPM / RPM):
      #     tokens_per_min  : ~12 000 tokens/min  → set conservatively to 10 000
      #     requests_per_min: 30 req/min           → rarely the bottleneck
      #
      #   Per-day (TPD / RPD):
      #     tokens_per_day  : 100 000 tokens/day  → long analysis runs will hit this
      #     requests_per_day: 1 000 req/day
      #
      # The proactive token bucket uses rate_limit_tokens_per_min to throttle
      # before hitting the API.  The reactive 429 handler reads Retry-After:
      #   - short Retry-After (≤ 300 s) → per-minute limit, sleep and retry
      #   - long  Retry-After (> 300 s) → daily limit, abort run cleanly
      #
      # Run  python tools/groq_rate_check.py  at any time to see live quota.
      rate_limit_tokens_per_min: 10000   # Conservative TPM ceiling (free tier ~12K/min)
      rate_limit_tokens_per_day: 100000  # TPD ceiling — analysis run aborts when hit
      rate_limit_requests_per_min: 30    # RPM ceiling (informational — rarely binding)
      daily_limit_threshold_secs: 300    # Retry-After > this → treat as daily limit hit
    ollama:
      base_url: http://localhost:11434
      model: mistral

# Watched contacts (emails will be fetched for these addresses and ALL their aliases)
# Format: name, email (primary), role (me | ex-wife | lawyer | other), aliases (optional list)
# Aliases = other addresses the same person has used over the years.
# You can also add aliases later with: python cli.py contacts alias -i <id> --add <email>
contacts:
  - name: Moi
    email: your@yahoo.com
    role: me
  - name: Ex-femme
    email: exwife@example.com
    role: ex-wife
    aliases:
      - exwife.old@hotmail.fr
      - exwife.pro@entreprise.com

# Predefined topics (AI will also discover new ones)
topics:
  - name: logement
    description: Appartement, loyer, charges, déménagement
  - name: enfants
    description: Garde, pension alimentaire, école, vacances
  - name: finances
    description: Comptabilité, partage des biens, dettes
  - name: divorce
    description: Procédure de divorce, accord, avocat
  - name: contradictions
    description: Déclarations contradictoires détectées

# Database
database:
  path: data/emails.db

# Analysis settings
analysis:
  batch_size: 20                  # Emails per LLM batch (classify/tone)
  contradiction_batch_size: 50    # Summaries per LLM call in contradiction Pass 1
  court_correlation_window: 14    # Days before/after each court event
  max_retries: 3
  retry_delay_seconds: 5
  skip_if_analyzed: true          # Skip already-processed emails (use --force to override)

# Report generation (Phase 4)
reports:
  output_dir: data/exports          # Default output directory for reports
  language: fr                       # Report language
  page_size: A4                      # PDF page size
